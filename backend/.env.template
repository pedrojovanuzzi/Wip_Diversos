PAYGO_FORMA_CREDITO=21
PAYGO_FORMA_DEBITO=22

# =========================================================
# MediaMTX (Portal de Câmeras / CFTV)
# =========================================================
# API de controle do MediaMTX (rede interna Docker)
MEDIAMTX_API_URL=http://mediamtx:9997
# Base pública WHEP (WebRTC) acessível pelo NAVEGADOR do cliente (não o host interno)
MEDIAMTX_WEBRTC_PUBLIC=https://cam.seudominio.com
# Base pública do playback server de gravações (porta 9996)
MEDIAMTX_PLAYBACK_PUBLIC=https://cam.seudominio.com/playback
# Retenção das gravações (deve casar com recordDeleteAfter do mediamtx.yml). 72h = 3 dias
MEDIAMTX_RECORD_DELETE_AFTER=72h
# IP público do servidor para os candidatos ICE do WebRTC (mídia fura a Cloudflare).
MEDIAMTX_WEBRTC_PUBLIC_IP=
# Pasta no host onde o MediaMTX grava (bind mount em backend/storage/recordings).
MEDIAMTX_RECORDINGS_PATH=/caminho/para/backend/storage/recordings

# ---- Servidor remoto de armazenamento das gravações ----
# As gravações deixam de ficar no diretório local e passam a residir neste
# servidor (acesso via SSH/SFTP).
CAMERA_STORAGE_HOST=
CAMERA_STORAGE_PORT=22
CAMERA_STORAGE_USER=
CAMERA_STORAGE_PASSWORD=
# Caminho das gravações no servidor remoto.
CAMERA_STORAGE_PATH=
# Teto global de conexões SFTP simultâneas (evita estourar o MaxStartups do sshd
# em rajadas). Deve ficar abaixo do limite não autenticado do servidor (padrão 10).
CAMERA_STORAGE_MAX_CONNECTIONS=5

# ---- Poda por movimento (CameraMotionService) ----
# Os parâmetros (sensibilidade, keyframes, "rabo" pós-movimento, ffmpeg etc.)
# agora ficam em src/config/cameraMotion.ts — não precisam ir no .env.

